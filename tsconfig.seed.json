{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "types/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "pages"]
}
